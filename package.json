{
  "name": "kontakt-atlas",
  "version": "0.1.0",
  "private": true,
  "description": "Lokale Electron-Desktopsoftware zur Verwaltung von Kontakten, Beziehungen, Fahrzeugen und Import-Entw\u00fcrfen.",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "prisma db push && concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env NODE_OPTIONS=--import=tsx VITE_DEV_SERVER_URL=http://localhost:5173 electron electron/main.ts\"",
    "build": "prisma db push && tsc --noEmit && vite build && node scripts/build-electron.mjs && electron-builder --dir",
    "test": "vitest run",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@vitejs/plugin-react": "^4.6.0",
    "vite": "^5.4.19",
    "typescript": "^5.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "reactflow": "^11.11.4",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "cross-env": "^7.0.3",
    "tsx": "^4.20.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.8",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "vitest": "^2.1.9",
    "jsdom": "^25.0.1",
    "electron-builder": "^24.13.3",
    "prisma": "^5.22.0",
    "electron": "^31.7.7"
  },
  "build": {
    "appId": "local.kontaktatlas.app",
    "productName": "KontaktAtlas",
    "files": [
      "dist/**",
      "dist-electron/**",
      "prisma/**",
      "storage/**",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    }
  },
  "author": "KontaktAtlas"
}
